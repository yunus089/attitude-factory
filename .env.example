# =============================================================
# Attitude Factory – Operator OS  |  Entwicklungs-Template
# =============================================================
# Kopiere diese Datei als .env und fülle die Werte aus.
# Für Produktion: Vorlage .env.production.example verwenden.
# NIEMALS .env in Git einchecken.
# =============================================================

# --- Datenbank (lokal über Docker Compose) ---
DATABASE_URL="postgresql://attitude:attitude_dev_password@127.0.0.1:5437/attitude_factory?schema=public"

# --- Better Auth ---
# Lokal kann ein kurzer Wert genommen werden.
# Produktion: openssl rand -base64 48
BETTER_AUTH_SECRET="replace-with-a-long-random-secret-min-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# --- Zugriffsschutz ---
# false = Registrierung erlaubt (nur für Dev-Seed)
AUTH_ALLOW_SIGN_UP="false"
# false = Auth-Prüfung umgangen (praktisch für lokale Tests ohne Session)
AUTH_ENFORCED="false"

# --- Seed-Accounts ---
# Werden von seed-auth.ts gelesen
SEED_GRUENDER_EMAIL="gruender@attitude-factory.com"
SEED_GRUENDER_PASSWORD="gruender-dev-2026!"
SEED_OPERATOR_EMAIL="operator@attitude-factory.com"
SEED_OPERATOR_PASSWORD="operator-dev-2026!"

# --- Upload-Speicher ---
# Relativer Pfad für lokale Uploads
UPLOAD_ROOT="./uploads"
