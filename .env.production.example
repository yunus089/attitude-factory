# =============================================================
# Attitude Factory – Operator OS  |  PRODUKTIONS-ENVIRONMENT
# =============================================================
# Diese Datei NICHT ins Git einchecken.
# Auf dem Server als /srv/attitude-factory/.env speichern.
# =============================================================

# --- Datenbank ---
# Interne Docker-Verbindung (Service-Name aus docker-compose.prod.yml)
DATABASE_URL="postgresql://attitude:CHANGE_ME_DB_PASSWORD@postgres:5432/attitude_factory?schema=public"

# --- Auth ---
# Mindestens 32 zufällige Zeichen – erzeugen mit: openssl rand -base64 48
BETTER_AUTH_SECRET="CHANGE_ME_LONG_RANDOM_SECRET_MIN_32_CHARS"
# Deine echte Domain (ohne Trailing-Slash)
BETTER_AUTH_URL="https://attitude-factory.com"

# --- Registrierung & Schutz ---
AUTH_ALLOW_SIGN_UP="false"
AUTH_ENFORCED="true"

# --- Seed-Accounts (nur für erstes Setup / Migration) ---
# Nach erstem Deployment Passwörter im Dashboard ändern!
SEED_GRUENDER_EMAIL="gruender@attitude-factory.com"
SEED_GRUENDER_PASSWORD="CHANGE_ME_GRUENDER_PASSWORD"
SEED_OPERATOR_EMAIL="operator@attitude-factory.com"
SEED_OPERATOR_PASSWORD="CHANGE_ME_OPERATOR_PASSWORD"

# --- Upload-Speicher ---
# Pfad im Container – wird als Volume gemounted
UPLOAD_ROOT="/app/uploads"

# --- Node ---
NODE_ENV="production"
PORT="3000"
